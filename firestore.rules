// firestore.rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isRoomParticipant(roomId) {
      return isSignedIn() && 
             request.auth.uid in get(/databases/$(database)/documents/rooms/$(roomId)).data.participants;
    }

    // Users collection
    match /users/{userId} {
      // Anyone can read user profiles
      allow read: if isSignedIn();
      
      // Users can only update their own profile
      allow create, update: if isOwner(userId);
      
      // Users cannot delete their profile
      allow delete: if false;
    }

    // Rooms collection
    match /rooms/{roomId} {
      // Users can read rooms they are part of
      allow read: if isSignedIn() && 
                     request.auth.uid in resource.data.participants;
      
      // Users can create rooms
      allow create: if isSignedIn() && 
                       request.auth.uid in request.resource.data.participants;
      
      // Only participants can update room
      allow update: if isRoomParticipant(roomId);
      
      // Rooms cannot be deleted
      allow delete: if false;
    }

    // Messages collection
    match /messages/{messageId} {
      // Users can read messages in rooms they belong to
      allow read: if isSignedIn() && 
                     isRoomParticipant(resource.data.roomId);
      
      // Users can create messages in rooms they belong to
      allow create: if isSignedIn() && 
                       isRoomParticipant(request.resource.data.roomId) &&
                       request.auth.uid == request.resource.data.senderId;
      
      // Users can update their own messages (for edits, reactions)
      allow update: if isSignedIn() && 
                       (isOwner(resource.data.senderId) || 
                        isRoomParticipant(resource.data.roomId));
      
      // Users can delete their own messages
      allow delete: if isSignedIn() && 
                       isOwner(resource.data.senderId);
    }

    // Typing indicators
    match /typing/{typingId} {
      // Anyone in the room can read typing indicators
      allow read: if isSignedIn();
      
      // Users can only create/update their own typing indicator
      allow create, update: if isSignedIn() && 
                               request.auth.uid == request.resource.data.userId;
      
      // Users can delete their own typing indicator
      allow delete: if isSignedIn() && 
                       request.auth.uid == resource.data.userId;
    }

    // Calls collection
    match /calls/{callId} {
      // Caller and receiver can read call data
      allow read: if isSignedIn() && 
                     (request.auth.uid == resource.data.callerId || 
                      request.auth.uid == resource.data.receiverId);
      
      // Only caller can create a call
      allow create: if isSignedIn() && 
                       request.auth.uid == request.resource.data.callerId;
      
      // Both participants can update call (for signaling)
      allow update: if isSignedIn() && 
                       (request.auth.uid == resource.data.callerId || 
                        request.auth.uid == resource.data.receiverId);
      
      // Calls should not be deleted
      allow delete: if false;
    }

    // Notifications collection
    match /notifications/{notificationId} {
      // Users can only read their own notifications
      allow read: if isSignedIn() && 
                     request.auth.uid == resource.data.userId;
      
      // System can create notifications (server-side)
      allow create: if isSignedIn();
      
      // Users can update their own notifications (mark as read)
      allow update: if isSignedIn() && 
                       request.auth.uid == resource.data.userId;
      
      // Users can delete their own notifications
      allow delete: if isSignedIn() && 
                       request.auth.uid == resource.data.userId;
    }
  }
}
